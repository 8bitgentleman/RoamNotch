<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- App Sandbox (ENABLE_APP_SANDBOX=NO) and the strict hardened-process model were
	     removed so the app can spawn /usr/bin/perl for the MediaRemote Now Playing adapter.
	     See CLAUDE.md "Media Player HUD" for the tradeoff. -->
</dict>
</plist>
